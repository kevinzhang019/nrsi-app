# Vercel Marketplace integrations expose either KV_* or UPSTASH_* names — code accepts both.
KV_REST_API_URL=
KV_REST_API_TOKEN=
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
MLB_USER_AGENT="nrsi-app/0.1 (kevinzhang019@gmail.com)"

# Supabase (Vercel Marketplace) — provisions all of these automatically.
# Server reads SUPABASE_URL with NEXT_PUBLIC_SUPABASE_URL as fallback.
# SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
# Required only when running scripts/migrate.mjs locally (DDL needs the
# direct, non-pooled connection on port 5432, not the 6543 pooler).
# POSTGRES_URL_NON_POOLING=
